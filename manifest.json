{
  "manifest_version": 3,
  "name": "Huntflow Menu Organizer",
  "version": "1.3.0",
  "description": "Группировка и сортировка вакансий по категориям в меню Huntflow.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.huntflow.ru/*",
    "*://*.huntflow.io/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.huntflow.ru/*",
        "*://*.huntflow.io/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ]
    }
  ]
}
